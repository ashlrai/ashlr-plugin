{
  "name": "ashlr-plugin",
  "version": "1.21.0",
  "description": "Claude Code plugin \u2014 open-source WOZCODE-style efficiency layer powered by @ashlr/core-efficiency.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ashlr": "./scripts/cli.ts"
  },
  "scripts": {
    "server": "bun run servers/efficiency-server.ts",
    "bench": "bun run servers/bench.ts",
    "test": "ASHLR_STATS_SYNC=1 bun test __tests__",
    "typecheck": "bunx tsc --noEmit",
    "publish:github": "bash scripts/publish.sh",
    "install-onnx-model": "bun run scripts/install-onnx-model.ts"
  },
  "dependencies": {
    "@ashlr/core-efficiency": "github:ashlrai/ashlr-core-efficiency#v0.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "minimatch": "^10.2.5",
    "postgres": "^3.4.9",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.22.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.20.0"
  }
}
