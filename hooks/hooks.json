{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|MultiEdit|mcp__ashlr-efficiency__ashlr__edit|mcp__ashlr-multi-edit__*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/policy-enforce.ts"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-read.ts"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-grep.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse-edit.ts"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/tool-redirect.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/commit-attribution.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write|Bash|mcp__ashlr-efficiency__ashlr__edit|mcp__ashlr-multi-edit__*",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/audit-upload.ts"
          }
        ]
      },
      {
        "matcher": "Edit|mcp__ashlr-efficiency__ashlr__edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/edit-batching-nudge.ts"
          },
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/genome-scribe-hook.ts"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Edit|Write|MultiEdit|mcp__ashlr-efficiency__ashlr__read|mcp__ashlr-efficiency__ashlr__grep|mcp__ashlr-efficiency__ashlr__edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/orient-nudge-hook.ts"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Edit|Write|Bash|MultiEdit|mcp__ashlr-efficiency__ashlr__read|mcp__ashlr-efficiency__ashlr__grep|mcp__ashlr-efficiency__ashlr__edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use-genome.ts"
          },
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/session-log-append.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/session-end-consolidate.ts"
          },
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/session-end-stats-gc.ts"
          }
        ]
      }
    ]
  }
}
