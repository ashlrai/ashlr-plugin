{
  "name": "ashlr",
  "version": "0.4.0",
  "description": "Open-source Claude Code plugin — token-efficient Read/Grep/Edit/SQL/Bash/Tree + hooks + status line + tri-agent delegation. WOZCODE alternative, MIT, zero telemetry.",
  "author": {
    "name": "Mason Wyatt",
    "url": "https://github.com/masonwyatt23"
  },
  "homepage": "https://plugin.ashlr.ai/",
  "repository": "https://github.com/masonwyatt23/ashlr-plugin",
  "license": "MIT",
  "keywords": ["claude-code", "plugin", "token-efficiency", "mcp", "ashlrcode", "wozcode-alternative"],
  "mcpServers": {
    "ashlr-efficiency": {
      "command": "bun",
      "args": ["run", "${CLAUDE_PLUGIN_ROOT}/servers/efficiency-server.ts"]
    },
    "ashlr-sql": {
      "command": "bun",
      "args": ["run", "${CLAUDE_PLUGIN_ROOT}/servers/sql-server.ts"]
    },
    "ashlr-bash": {
      "command": "bun",
      "args": ["run", "${CLAUDE_PLUGIN_ROOT}/servers/bash-server.ts"]
    },
    "ashlr-tree": {
      "command": "bun",
      "args": ["run", "${CLAUDE_PLUGIN_ROOT}/servers/tree-server.ts"]
    }
  }
}
